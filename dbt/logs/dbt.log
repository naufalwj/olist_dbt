  create or replace view `olist_dbt`.`staging`.`stg_geolocations`
  
  as (
    WITH raw_geolocations AS (
SELECT
    DISTINCT
    geolocation_zip_code_prefix::bigint as zip_code,
    geolocation_state::string as state,
    geolocation_city::string as city,
    bs.name as state_name
FROM
    `olist_dbt`.`source`.`olist_geolocation_dataset`
LEFT JOIN
    `olist_dbt`.`default`.`seed_brazil_state` as bs
    ON geolocation_state = bs.shortcode
)

SELECT
    zip_code,
    state as short_state,
    LOWER(
        
    TRIM(
      REGEXP_REPLACE(
        REGEXP_REPLACE(
        TRANSLATE(city, 'áàâãäéèêëíìîïóòôõöúùûüçñ', 'aaaaaeeeeiiiiooooouuuucn'),
        '-', ' ' ),
        '\\s+', ' ')
    )

    ) AS clean_city,
    
    TRIM(
      REGEXP_REPLACE(
        REGEXP_REPLACE(
        TRANSLATE(state_name, 'áàâãäéèêëíìîïóòôõöúùûüçñ', 'aaaaaeeeeiiiiooooouuuucn'),
        '-', ' ' ),
        '\\s+', ' ')
    )
 as clean_state
FROM
    raw_geolocations
  )

